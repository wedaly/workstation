# If not running interactively, don't do anything
[[ $- != *i* ]] && return

_remove_from_path() {
    local p=":$PATH:"
    p="${p//:$1:/:}"
    p="${p#:}"
    p="${p%:}"
    PATH="$p"
}

prepend_path() {
    _remove_from_path "$1"
    export PATH="$1:$PATH"
}

append_path() {
    _remove_from_path "$1"
    export PATH="$PATH:$1"
}

# history
export HISTFILESIZE=100000
export HISTSIZE=100000
export HISTCONTROL=ignoredups
shopt -s histappend
export PROMPT_COMMAND="history -a"

# terminal
export TERMINAL=xterm
export KEYTIMEOUT=1

# don't exit on ctrl-d
export IGNOREEOF=10

# prompt
PS1='\[\033[0;34m\][\H:\w]\[\033[00m\] '

{{- if eq .chezmoi.os "linux" }}
# ls colors
alias ls='ls --color=auto'
{{- end }}

# aretext and vim key bindings everywhere
set -o vi
export EDITOR=aretext
export GIT_EDITOR=aretext
export SUDO_EDITOR=$HOME/go/bin/aretext

# git aliases
alias gb='git branch'
alias gc='git commit'
alias gco='git checkout'
alias wip='git add -u && git commit -m wip'
alias gd='git diff'

gr() {
    branches=$(git branch --all)
    if echo "$branches" | grep "origin/master" > /dev/null; then
        b="origin/master"
    else 
        b="origin/main"
    fi
    git rebase -i "$b"
}

gdm() {
    branches=$(git branch --all)
    if echo "$branches" | grep "origin/master" > /dev/null; then
        b="origin/master"
    else 
        b="origin/main"
    fi
    git diff "$b"...HEAD
}

gp() {
    b=$(git rev-parse --abbrev-ref HEAD)
    git push origin $b $@
}

# git completions
source $HOME/.git-completion.bash
__git_complete gb _git_branch
__git_complete gco _git_checkout

# scripts
append_path "$HOME/bin"

{{- if eq .chezmoi.os "darwin" }}
export BASH_SILENCE_DEPRECATION_WARNING=1

# homebrew
eval "$(/opt/homebrew/bin/brew shellenv)"
prepend_path "/opt/homebrew/opt/gnu-sed/libexec/gnubin"
prepend_path "/opt/homebrew/bin:$(brew --prefix python)/libexec/bin"
prepend_path "$(brew --prefix python)/libexec/bin"

# homebrew bash-completion@2
[[ -r "/opt/homebrew/etc/profile.d/bash_completion.sh" ]] && . "/opt/homebrew/etc/profile.d/bash_completion.sh"

# pipx
prepend_path "$(pipx environment --value PIPX_BIN_DIR)"

# xdg config
export XDG_CONFIG_HOME=$HOME/.config
{{- end }}

# python interpreter enable readline and vi-mode
export PYTHONSTARTUP=~/.pythonrc

# rust
if [ -e $HOME/.cargo/env ]; then
    source $HOME/.cargo/env # rustup
else
    append_path "$HOME/.cargo/bin"
fi

# go
append_path "/usr/local/go/bin"
append_path "$HOME/go/bin"

# nodejs
export NVM_DIR="$HOME/.config/nvm"
if [ -d "$NVM_DIR" ]; then
    latest_node_version=$(ls "$NVM_DIR/versions/node" | sort --reverse | head -n 1)
    if [ -n "$latest_node_version" ]; then
        append_path "$NVM_DIR/versions/node/$latest_node_version/bin"
    fi
fi

# fuzzy find
export FZF_DEFAULT_COMMAND='rg --files'

dir () {
    cd $(find . -type d ! -path "*/.git/*" 2> /dev/null | fzf --reverse || pwd)
}

repo() {
    cd $(find $HOME/repos -maxdepth 5 -type d -name ".git" | xargs -I{} dirname {} | fzf --reverse || pwd)
}

alias r=repo
alias repos=repo

adhoc () {
    cd $(find $HOME/adhoc -mindepth 1 -maxdepth 1 -type d | fzf --reverse || pwd)
}

# gospelunk
gofind () {
    gospelunk list -t {{"$'{{ range .Defs }}-line={{.Line}} {{.Path|RelPath}} {{.Name}}\\n{{ end }}'"}} $@ \
    | fzf --reverse \
    | cut -d " " -f 1-2 \
    | xargs -r aretext
}

# devlog
alias dle="devlog edit"
alias dlt="devlog tail | less"
alias todo="devlog todo"

# aretext
alias at="aretext"

# kubectl (lazy)
if command -v kubectl >/dev/null 2>&1; then
    alias k=kubectl
    __platform_kubectl_complete() {
        {{- if eq .chezmoi.os "linux" }}
            complete -F "$1" k
        {{- else if eq .chezmoi.os "darwin" }}
            complete -o default -F "$1" k
        {{- end }}
    }

    __kubectl_lazy_completion() {
        unset -f __kubectl_lazy_completion
        source <(kubectl completion bash)
        __platform_kubectl_complete __start_kubectl
        __start_kubectl "$@"
    }
    __platform_kubectl_complete __kubectl_lazy_completion
fi

{{- if eq .chezmoi.os "linux" }}
# firefox / wayland
export MOZ_ENABLE_WAYLAND=1
{{- end }}

{{- if eq .chezmoi.os "linux" }}
# ssh keychain
if ! ssh-add -l >/dev/null 2>&1; then
    for key in "$HOME/.ssh/id_ed25519" "$HOME/.ssh/id_rsa"; do
        if [ -f "$key" ]; then
            eval $(keychain --eval --timeout 480 --quiet "$(basename "$key")")
        fi
    done
fi
{{- end }}

# start tmux or attach to existing session
TMUX_SESSION="${TMUX_SESSION:-default}"
if [ -z "$TMUX" ] && [ -z "$DISABLE_TMUX" ]; then
    tmux attach -t "$TMUX_SESSION" || tmux new -s "$TMUX_SESSION"
fi

# user specific aliases and functions
if [ -f ~/.bash_private ]; then
    source $HOME/.bash_private
fi
if [ -d ~/.bashrc.d ]; then
    for rc in ~/.bashrc.d/*; do
        if [ -f "$rc" ]; then
            . "$rc"
        fi
    done
fi
unset rc
